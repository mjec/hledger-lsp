; Comprehensive Alignment Demonstration
; This file demonstrates all alignment features of the hledger formatter
; Format this file to see the alignment in action

; ============================================================================
; 1. Basic Amount Alignment - Currency Symbols and Decimals
; ============================================================================

commodity $1,000.00  ;Standard format, no space,
commodity EUR 1 000 000,00  ;Comma as decimal mark, space as thousand seperator, space between commodity
commodity INR 1.000,00  ;Comma as decimal Mark, decimal as thousand sepeerator.
commodity GBP1,000.000  ;Hight precsision decimals

2024-01-01 No Negatives
    expenses:food                               $ 25.005
    expenses:household                          $123.000
    assets:checking

2024-01-02 Mixed signs
    expenses:entertainment                      $ 10.000;should be left without decimal
    expenses:transport                          $ 20.000
    assets:checking                             $-30.000

2024-01-03 Whole Numbers vs Decimals
    expenses:utilities                   EUR  10 000,00;should be left without decimals
    expenses:internet                    EUR      45,99
    assets:checking                      EUR -10 045,99;fix syntax highlightng

2024-01-03 High Precison Decimals
    expenses:food                            GBP 100.000
    expenses:entertainment                   GBP 100.101
    assets:pounds                            GBP-200.1010

; ============================================================================
; 2. Right-Side Commodities
; ============================================================================

commodity 1,000.00 USD
commodity 1,000.00SPs

2024-01-04 European Expenses
    expenses:travel                              100.00 USD
    expenses:food                                 25.50 USD
    assets:euro-account                         -125.50 USD

2024-01-04 European Expenses
    expenses:travel                              100.00SPs
    expenses:food                                 25.50SPs
    assets:euro-account                         -125.50SPs
; ============================================================================
; 3. Mixed Currency Symbols (Different Lengths)
; ============================================================================

2024-01-05 Multi-Currency Transaction
    expenses:international                 €uro   50.00  @@ $50.000
    expenses:local                            $   75.000
    assets:checking                           $ -125.000

2024-01-05 No Formatting undeclared commodity
    expenses:international                   €uro 50.00 @@ $50.000
    expenses:local
; ============================================================================
; 4. Cost Alignment - @ Symbols and Cost Amounts
; ============================================================================
commodity AAPL
commodity MSFT
commodity TSLA
commodity NVDA

2024-01-10 Stock Purchase - Unit Costs
    assets:stock                                  10 AAPL @ $150.000
    assets:stock                                   5 MSFT @ $320.000
    assets:checking

2024-01-11 Currency Exchange - Unit Costs
    assets:euros                            EUR  100,00   @ $1.000
    assets:pounds                           GBP   50.0000 @ $1.000
    assets:checking                           $ -172.000

2024-01-12 Total Cost Notation (@@)
    assets:stock                                  15 TSLA @@ $3.000
    assets:stock                                   8 NVDA @@ $4.000
    assets:checking

; ============================================================================
; 5. Balance Assertions - = Symbols and Assertion Amounts
; ============================================================================

2024-01-15 Checking Balance Assertions
    assets:checking                            $ 100.000 = $ -11.000
    assets:savings                             $  50.000 = $  50.000
    income:salary                              $-150.000

2024-01-16 Different Assertion Amounts
    assets:checking                             $ 25.000 = $1.000
    assets:savings                              $  5.000 = $2.000
    expenses:transfer                           $-30.000

; ============================================================================
; 6. Combined Costs AND Assertions
; ============================================================================

2024-01-20 Stock with Balance Tracking
    assets:stock                                  10 AAPL @ $100.000 = $  1.000
    assets:stock                                   5 MSFT @ $200.000 = $  1.000
    assets:checking                                                  = $500.000

2024-01-21 Complex Multi-Commodity
    assets:stock:tech                             20 GOOGL @ $120.000 = $  2.000
    assets:stock:auto                              8 TSLA  @ $200.000 = $  1.000
    assets:checking                                                   = $ -3.000

; ============================================================================
; 7. Mixed Transaction - Some with Costs, Some without
; ============================================================================

2024-01-25 Partial Cost Transaction
    assets:stock                                  10     AAPL @ $150.000
    expenses:fees                                $10.000
    assets:checking

; ============================================================================
; 8. Mixed Transaction - Some with Assertions, Some without
; ============================================================================

2024-01-26 Partial Assertion Transaction
    assets:checking                            $ 100.000 = $1.000
    income:salary                              $-100.000

; ============================================================================
; 9. Negative Amounts in Costs
; ============================================================================

2024-01-27 Stock Sale (Negative Units)
    assets:stock                                         @ $155.000
    assets:cash                                   $1.000
    income:capital-gains

; ============================================================================
; 10. Very Long Account Names
; ============================================================================

2024-01-28 Long Account Names
    assets:investments:retirement:401k:tech-stocks  10 AAPL @ $150.000
    assets:investments:brokerage:cash

; ============================================================================
; 11. Comments with Aligned Amounts
; ============================================================================

2024-01-29 Transaction with Comments
    expenses:food                               $ 50.000;weekly groceries
    expenses:gas                                $ 40.000;fuel for car
    assets:checking                             $-90.000;payment

; ============================================================================
; 12. Inferred Amounts (No Explicit Amount on Last Posting)
; ============================================================================

2024-01-30 Inferred Amount
    expenses:food                                $75.000
    expenses:entertainment                       $25.000
    assets:checking

; ============================================================================
; 13. Three-Way Cost/Assertion Alignment
; ============================================================================

2024-02-01 Ultimate Alignment Test
    assets:stock:tech                             15 AAPL @@ $145.000 = $  2.000
    assets:stock:auto                              8 TSLA @  $195.000 = $  1.000
    assets:bonds                                  10 BND  @  $ 80.000 = $800.000
    assets:checking

; ============================================================================
; 14. Commodity Directives with Different Formats
; ============================================================================

2024-02-05 Using Commodity Formats
    expenses:shopping                          $   1.000
    expenses:european-travel                 EUR 500,00
    expenses:uk-travel                       GBP 250.0000
    assets:checking

; ============================================================================
; 15. Edge Case - Zero Amounts
; ============================================================================

2024-02-10 Zero Amount
    assets:clearing                               $0.000
    income:adjustment                             $0.000

; ============================================================================
; 16. Multiple Commodities in Same Transaction
; ============================================================================

2024-02-15 Multi-Commodity Exchange
    assets:euros                            EUR  100,00   @ $1.000
    assets:pounds                           GBP   50.0000 @ $1.000
    assets:dollars                            $ -172.000
    income:forex-gains                        $    0.000

; ============================================================================
; 17. Status Markers and Codes
; ============================================================================

2024-02-20 * (CHK-001) Cleared Transaction with Code
    expenses:rent                                $ 1.000
    assets:checking                              $-1.000

2024-02-21 ! Pending Transaction
    expenses:utilities                         $ 150.000
    assets:checking                            $-150.000

; ============================================================================
; End of Alignment Demonstration
; ============================================================================

